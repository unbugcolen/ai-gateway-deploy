# LiteLLM Docker 镜像。
# - main-latest 会跟随上游最新的数据库版镜像。
# - 生产环境建议运维验证后固定版本 tag 或 digest。
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest

# 容器时区。保持 Asia/Shanghai，便于 UI 日志与服务器日志按团队时区对齐。
TZ=Asia/Shanghai

# 固定 IP 服务器对外暴露的端口。
# 默认客户端访问地址为 http://<SERVER_IP>:4000。
PUBLIC_PORT=4000

# 外部 PostgreSQL 连接串。生产环境必须改成运维提供的数据库地址。
# 示例：postgresql://litellm:password@postgres.example.internal:5432/litellm
# 如外部数据库要求 SSL，请按数据库规范追加 sslmode 等参数。
DATABASE_URL=postgresql://litellm:CHANGE_ME@postgres.example.internal:5432/litellm

# 本地/测试随附 PostgreSQL 配置，仅 docker-compose.bundled.yml 使用。
# 生产环境使用外部 DATABASE_URL 时，这些值不会被基础 docker-compose.yml 使用。
POSTGRES_USER=litellm

# 本地/测试随附 PostgreSQL 数据库名。
POSTGRES_DB=litellm

# 本地/测试随附 PostgreSQL 密码。部署脚本会在首次部署时自动生成。
# 数据创建后不要单独修改此值，除非同时更新 PostgreSQL 内部密码。
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# LiteLLM 密钥配置。首次部署后必须保持 LITELLM_SALT_KEY 稳定，
# 它用于加密/解密已保存的供应商凭据。
# LiteLLM 管理 API 和 UI 登录的主密钥。按 root 密码级别保管。
LITELLM_MASTER_KEY=sk-CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# LiteLLM 用于加密/解密供应商凭据的盐值。
# 首次部署后修改它，可能导致已保存的 key 无法读取。
LITELLM_SALT_KEY=sk-CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# 可选供应商 key。建议部署后在远端 .env 修改，或通过 LiteLLM UI 添加模型；
# 不要把真实 key 提交到 git。
# Anthropic key。litellm/config.yaml 里的 Claude 别名需要它。
ANTHROPIC_API_KEY=

# OpenAI key。litellm/config.yaml 里的 OpenAI 模型别名需要它。
OPENAI_API_KEY=

# Gemini key。litellm/config.yaml 里的 Gemini 模型别名需要它。
GEMINI_API_KEY=

# DeepSeek key。litellm/config.yaml 里的 DeepSeek 模型别名需要它。
DEEPSEEK_API_KEY=

# OpenRouter key。预留给后续 OpenRouter 模型别名使用。
OPENROUTER_API_KEY=
