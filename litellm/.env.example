# Image / runtime
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest
TZ=Asia/Shanghai
PUBLIC_PORT=4000

# Database
POSTGRES_USER=litellm
POSTGRES_DB=litellm
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# LiteLLM secrets. Keep LITELLM_SALT_KEY stable after first deploy; it is used
# to encrypt/decrypt stored credentials.
LITELLM_MASTER_KEY=sk-CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT
LITELLM_SALT_KEY=sk-CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# Optional provider keys. Prefer editing the remote .env or adding models
# through LiteLLM UI after deployment; do not commit real keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
