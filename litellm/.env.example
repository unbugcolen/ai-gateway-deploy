# LiteLLM Docker image.
# - main-latest tracks upstream latest database-enabled image.
# - For production stability, ops can pin a digest or version tag after validation.
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest

# Container timezone. Keep Asia/Shanghai so UI logs and server logs match the team timezone.
TZ=Asia/Shanghai

# Host port exposed on the fixed IP server.
# Clients will use http://<SERVER_IP>:4000 by default.
PUBLIC_PORT=4000

# Database
# PostgreSQL username created by the postgres container.
POSTGRES_USER=litellm

# PostgreSQL database name used by LiteLLM.
POSTGRES_DB=litellm

# PostgreSQL password. The deploy script generates this on first deployment.
# Do not change it after data has been created unless you also update Postgres.
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# LiteLLM secrets. Keep LITELLM_SALT_KEY stable after first deploy; it is used
# to encrypt/decrypt stored credentials.
# Master key for LiteLLM admin API and UI login. Treat it like a root password.
LITELLM_MASTER_KEY=sk-CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# Salt key used by LiteLLM to encrypt/decrypt stored provider credentials.
# Changing it after first deploy can make stored keys unreadable.
LITELLM_SALT_KEY=sk-CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# Optional provider keys. Prefer editing the remote .env or adding models
# through LiteLLM UI after deployment; do not commit real keys.
# Anthropic key. Required by Claude aliases in litellm/config.yaml.
ANTHROPIC_API_KEY=

# OpenAI key. Required by OpenAI model aliases in litellm/config.yaml.
OPENAI_API_KEY=

# Gemini key. Required by Gemini model aliases in litellm/config.yaml.
GEMINI_API_KEY=

# DeepSeek key. Required by DeepSeek model aliases in litellm/config.yaml.
DEEPSEEK_API_KEY=

# OpenRouter key. Reserved for future OpenRouter aliases.
OPENROUTER_API_KEY=
