# LiteLLM 专用配置。
# 复制为 .env.litellm：
# cp .env.litellm.example .env.litellm
#
# 这里的 key 只给 LiteLLM 容器使用，不发给员工。
# 员工只拿 LiteLLM UI/API 里创建的 virtual key。

# LiteLLM 外部 PostgreSQL 连接串。
# 建议与 New API 使用不同数据库，避免表结构互相污染。
# 本地 Docker Desktop 连接宿主机 PostgreSQL 示例：
# DATABASE_URL=postgresql://litellm:password@host.docker.internal:5432/litellm_hybrid
DATABASE_URL=postgresql://litellm:CHANGE_ME@postgres.example.internal:5432/litellm_hybrid

# LiteLLM 管理 API 和 UI 登录的主密钥。按 root 密码级别保管，不发给员工。
LITELLM_MASTER_KEY=sk-CHANGE_ME_GENERATE_RANDOM_VALUE

# LiteLLM 用于加密/解密已保存凭据的盐值。首次部署后必须保持稳定。
LITELLM_SALT_KEY=sk-CHANGE_ME_GENERATE_RANDOM_VALUE

# Claude 官方 API key。
# Claude 直连 LiteLLM，不经过 New API。
ANTHROPIC_API_KEY=

# Gemini 官方 API key。
# Gemini 直连 LiteLLM，不经过 New API。
GEMINI_API_KEY=

# OpenAI 官方 API key。
# GPT 直连 LiteLLM，不经过 New API。
# 建议只给管理员/高级研发开放 gpt-5.5，普通研发默认使用 gpt-4.1 或 New API 下游模型。
OPENAI_API_KEY=

# New API 服务 token。
# 在 New API 后台创建一个专门给 LiteLLM 使用的 token，模型权限只开放 DeepSeek / Qwen / Kimi。
# 员工不直接拿这个 token。
NEW_API_SERVICE_TOKEN=sk-CHANGE_ME_CREATE_IN_NEW_API

# LiteLLM 调 New API 的 OpenAI-compatible 地址。
# 同一 docker-compose 网络内使用服务名 new-api，不要写 localhost。
NEW_API_OPENAI_BASE_URL=http://new-api:3000/v1

# 可选：Langfuse 观测配置。
# 推荐先只接 LiteLLM 元数据/成本，不记录 prompt/response 正文。
# 开启方式见 litellm-observability.langfuse.snippet.yaml 和 docs/observability-langfuse-plan.md。
# 如果用 Langfuse Cloud，LANGFUSE_HOST 可填 https://cloud.langfuse.com。
# 如果用公司自建 Langfuse，LANGFUSE_HOST 填自建地址，例如 https://langfuse.example.com。
# 如果 Langfuse 跑在本机宿主机，Docker Desktop 下可填 http://host.docker.internal:3000。
# 如果 Langfuse 与 LiteLLM 在同一个 Docker 网络，填 Langfuse Web 服务名，例如 http://langfuse-web:3000。
# LANGFUSE_PUBLIC_KEY=pk-CHANGE_ME
# LANGFUSE_SECRET_KEY=sk-CHANGE_ME
# LANGFUSE_HOST=https://cloud.langfuse.com
