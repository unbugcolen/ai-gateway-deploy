# 共享配置：只放 Docker Compose 和两个服务都可能用到的通用变量。
# 复制为 .env：
# cp .env.example .env
#
# 敏感运行时配置请分别放到：
# - .env.litellm：LiteLLM 数据库、Claude/Gemini/GPT key、New API 服务 token。
# - .env.new-api：New API 数据库、Redis、后台密钥和运行策略。

# Docker Compose 项目名。生产环境同一台机器部署多套时需要改成不同名称。
COMPOSE_PROJECT_NAME=ai-gateway-hybrid

# LiteLLM Docker 镜像。生产环境建议固定版本 tag 或 digest。
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest

# New API Docker 镜像。生产环境建议固定版本 tag 或 digest。
NEW_API_IMAGE=calciumion/new-api:latest

# 容器时区。保持 Asia/Shanghai，便于 UI 日志与服务器日志按团队时区对齐。
TZ=Asia/Shanghai

# LiteLLM 对员工和业务系统暴露的监听地址与端口。
# 本地默认 4100，避免和已有 LiteLLM 4000 冲突；生产可改成 4000。
LITELLM_PUBLIC_BIND=0.0.0.0
LITELLM_PUBLIC_PORT=4100

# New API 后台端口。
# 默认只绑定本机 127.0.0.1，避免员工绕过 LiteLLM 直接访问渠道池。
# 本地默认 3100，避免和已有 New API 3000 冲突；生产可改成 3000。
NEW_API_ADMIN_BIND=127.0.0.1
NEW_API_ADMIN_PORT=3100

# 可选：如果服务器访问上游模型供应商需要代理，在这里配置。
# Docker 容器访问宿主机代理常用 host.docker.internal。
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
# http_proxy=http://host.docker.internal:7897
# https_proxy=http://host.docker.internal:7897
# NO_PROXY=localhost,127.0.0.1,new-api,litellm,host.docker.internal,.internal
# no_proxy=localhost,127.0.0.1,new-api,litellm,host.docker.internal,.internal
