# New API 专用配置。
# 复制为 .env.new-api：
# cp .env.new-api.example .env.new-api
#
# New API 在该方案里只做 DeepSeek / Qwen / Kimi 渠道池。
# 员工不直接访问 New API，也不直接拿 New API token。

# New API 对外展示和回调使用的基础地址。
# 如果只给运维本机或 SSH 隧道访问，可以保持 localhost。
FRONTEND_BASE_URL=http://localhost:3100

# New API 外部 PostgreSQL 连接串。
# 本地 Docker Desktop 连接宿主机 PostgreSQL 示例：
# SQL_DSN=postgresql://newapi:password@host.docker.internal:5432/newapi_hybrid
SQL_DSN=postgresql://newapi:CHANGE_ME@postgres.example.internal:5432/newapi_hybrid

# New API 外部 Redis 连接串。
# 本地 Docker Desktop 连接宿主机 Redis 示例：
# REDIS_CONN_STRING=redis://host.docker.internal:6379/1
REDIS_CONN_STRING=redis://redis.example.internal:6379/1

# New API 会话签名密钥。修改后会使已有登录会话失效。
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE

# New API 数据加密密钥。修改后可能导致已加密数据无法读取。
CRYPTO_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE

# false 表示 New API 不自动创建默认 token，由管理员显式发放服务 token。
GENERATE_DEFAULT_TOKEN=false

# 开启服务端错误日志，便于排查 New API 渠道池问题。
ERROR_LOG_ENABLED=true

# 开启批量用量更新，适合团队用量统计。
BATCH_UPDATE_ENABLED=true

# 开启内存缓存，提高请求性能。
MEMORY_CACHE_ENABLED=true

# 流式响应超时时间，单位秒。Claude Code / 编码 agent 可能需要较长流式输出。
STREAMING_TIMEOUT=300

# New API 公共 API 按来源 IP 的粗粒度限流。
# 真正员工配额建议放在 LiteLLM virtual key 上。
GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=300
GLOBAL_API_RATE_LIMIT_DURATION=180

# New API 定期从渠道同步上游模型列表。
CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true
