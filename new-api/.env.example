# New API Docker 镜像。
# - latest 方便首次部署。
# - 生产环境建议运维验证后固定版本 tag 或 digest。
NEW_API_IMAGE=calciumion/new-api:latest

# 容器时区。保持 Asia/Shanghai，便于 UI 日志与服务器日志按团队时区对齐。
TZ=Asia/Shanghai

# 固定 IP 服务器对外暴露的端口。
# 默认客户端访问地址为 http://<SERVER_IP>:3000。
PUBLIC_PORT=3000

# New API 对外展示和回调使用的基础地址。
# 固定 IP 部署可用 http://<SERVER_IP>:3000；绑定 HTTPS 后改成 https://api.example.com。
FRONTEND_BASE_URL=http://YOUR_SERVER_IP:3000

# 外部 PostgreSQL 连接串。生产环境必须改成运维提供的数据库地址。
# 示例：postgresql://newapi:password@postgres.example.internal:5432/newapi
# 如外部数据库要求 SSL，请按数据库规范追加 sslmode 等参数。
SQL_DSN=postgresql://newapi:CHANGE_ME@postgres.example.internal:5432/newapi

# 外部 Redis 连接串。生产环境必须改成运维提供的 Redis 地址。
# 示例：redis://:password@redis.example.internal:6379/0
# 无密码 Redis 可使用 redis://redis.example.internal:6379/0。
REDIS_CONN_STRING=redis://redis.example.internal:6379/0

# 本地/测试随附 PostgreSQL 配置，仅 docker-compose.bundled.yml 使用。
# 生产环境使用外部 SQL_DSN 时，这些值不会被基础 docker-compose.yml 使用。
POSTGRES_USER=newapi

# 本地/测试随附 PostgreSQL 数据库名。
POSTGRES_DB=newapi

# 本地/测试随附 PostgreSQL 密码。部署脚本会在首次部署时自动生成。
# 数据创建后不要单独修改此值，除非同时更新 PostgreSQL 内部密码。
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# New API 密钥配置。首次部署后应保持稳定；
# 修改它们可能导致登录会话失效或加密数据无法读取。
# 会话签名密钥。修改后会使已有登录会话失效。
SESSION_SECRET=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# 数据加密密钥。修改后可能导致已加密数据无法读取。
CRYPTO_SECRET=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# 团队默认策略。
# false 表示 New API 不会自动创建默认 API token。
# 建议保持 false，由运维按成员或项目显式发放 token。
GENERATE_DEFAULT_TOKEN=false

# 开启服务端错误日志，便于运维排查问题。
ERROR_LOG_ENABLED=true

# 开启批量用量更新，适合团队用量统计。
BATCH_UPDATE_ENABLED=true

# 开启内存缓存，提高请求性能。
MEMORY_CACHE_ENABLED=true

# 流式响应超时时间，单位秒。Claude Code / 编码 agent 可能需要较长流式输出。
STREAMING_TIMEOUT=300

# 公共 API 按来源 IP 的粗粒度限流。上线后可根据团队流量调整。
# 在 per-token 配额生效前，先提供一层 IP 级保护。
GLOBAL_API_RATE_LIMIT_ENABLE=true

# 每个来源 IP 在时间窗口内允许的最大请求数。
GLOBAL_API_RATE_LIMIT=300

# GLOBAL_API_RATE_LIMIT 的时间窗口，单位秒。
GLOBAL_API_RATE_LIMIT_DURATION=180

# 保持供应商模型元数据更新。
# 定期从已配置渠道刷新上游模型列表。
CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true
