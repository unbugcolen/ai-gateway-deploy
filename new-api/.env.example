# New API Docker image.
# - latest is convenient for first deployment.
# - For production stability, ops can pin a tested tag or digest.
NEW_API_IMAGE=calciumion/new-api:latest

# Container timezone. Keep Asia/Shanghai so UI logs and server logs match the team timezone.
TZ=Asia/Shanghai

# Host port exposed on the fixed IP server.
# Clients will use http://<SERVER_IP>:3000 by default.
PUBLIC_PORT=3000

# Public base URL shown to New API.
# Use http://<SERVER_IP>:3000 for fixed-IP deployment, or https://api.example.com after binding HTTPS.
FRONTEND_BASE_URL=http://YOUR_SERVER_IP:3000

# Database
# PostgreSQL username created by the postgres container.
POSTGRES_USER=newapi

# PostgreSQL database name used by New API.
POSTGRES_DB=newapi

# PostgreSQL password. The deploy script generates this on first deployment.
# Do not change it after data has been created unless you also update Postgres.
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# New API secrets. Keep stable after first deploy; changing them can invalidate
# sessions and encrypted data.
# Session signing secret. Changing it invalidates login sessions.
SESSION_SECRET=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# Data encryption secret. Changing it can make encrypted data unreadable.
CRYPTO_SECRET=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# Team defaults
# false means New API will not create a default API token automatically.
# Keep false so ops can issue per-user/per-project tokens explicitly.
GENERATE_DEFAULT_TOKEN=false

# Enable server-side error logs for operation diagnosis.
ERROR_LOG_ENABLED=true

# Enable batch usage update. Recommended for team usage accounting.
BATCH_UPDATE_ENABLED=true

# Enable in-memory cache for better request performance.
MEMORY_CACHE_ENABLED=true

# Streaming response timeout in seconds. Claude Code / coding agents can require long streams.
STREAMING_TIMEOUT=300

# Public API rate limit per source IP. Adjust after observing team traffic.
# Enable coarse IP-level protection before per-token quota is evaluated.
GLOBAL_API_RATE_LIMIT_ENABLE=true

# Max requests per duration window per source IP.
GLOBAL_API_RATE_LIMIT=300

# Duration window in seconds for GLOBAL_API_RATE_LIMIT.
GLOBAL_API_RATE_LIMIT_DURATION=180

# Keep provider model metadata fresh.
# Periodically refresh upstream model lists from configured channels.
CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true
