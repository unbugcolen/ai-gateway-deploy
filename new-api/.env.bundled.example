# New API 本地/测试环境模板。
# 使用方式：cp .env.bundled.example .env，然后执行
# docker compose -f docker-compose.yml -f docker-compose.bundled.yml up -d

NEW_API_IMAGE=calciumion/new-api:latest
TZ=Asia/Shanghai
PUBLIC_PORT=3000
FRONTEND_BASE_URL=http://localhost:3000

# 本地/测试随附 PostgreSQL 配置，仅 docker-compose.bundled.yml 使用。
POSTGRES_USER=newapi
POSTGRES_DB=newapi
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

# New API 密钥配置。首次部署后应保持稳定。
SESSION_SECRET=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT
CRYPTO_SECRET=CHANGE_ME_GENERATED_BY_DEPLOY_SCRIPT

GENERATE_DEFAULT_TOKEN=false
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
MEMORY_CACHE_ENABLED=true
STREAMING_TIMEOUT=300
GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=300
GLOBAL_API_RATE_LIMIT_DURATION=180
CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true
