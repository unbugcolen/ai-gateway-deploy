# 组合方案：LiteLLM 作为团队统一入口，New API 作为下游模型渠道池。
# 使用方式：
# 1. 复制本文件为 .env。
# 2. 先启动 new-api，进入 New API 后台配置供应商渠道。
# 3. 在 New API 创建一个“仅给 LiteLLM 使用”的服务 token，填入 NEW_API_SERVICE_TOKEN。
# 4. 再启动 litellm，由 LiteLLM 对员工发放 virtual key。

# Docker Compose 项目名。生产环境同一台机器部署多套时需要改成不同名称。
COMPOSE_PROJECT_NAME=ai-gateway-chain

# LiteLLM Docker 镜像。
# 生产环境建议运维验证后固定版本 tag 或 digest。
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest

# New API Docker 镜像。
# 生产环境建议运维验证后固定版本 tag 或 digest。
NEW_API_IMAGE=calciumion/new-api:latest

# 容器时区。保持 Asia/Shanghai，便于 UI 日志与服务器日志按团队时区对齐。
TZ=Asia/Shanghai

# LiteLLM 对员工和业务系统暴露的监听地址与端口。
# 生产环境可以保持 0.0.0.0:4000，再通过防火墙、Nginx、VPN 或 Cloudflare Access 控制访问。
LITELLM_PUBLIC_BIND=0.0.0.0
LITELLM_PUBLIC_PORT=4000

# New API 后台端口。默认只绑定本机 127.0.0.1，避免员工绕过 LiteLLM 直接访问渠道池。
# 远程运维可通过 SSH 隧道访问：ssh -L 3000:127.0.0.1:3000 root@<server-ip>
NEW_API_ADMIN_BIND=127.0.0.1
NEW_API_ADMIN_PORT=3000

# New API 对外展示和回调使用的基础地址。
# 如果只给运维本机或内网访问，可以保持 localhost；绑定域名/HTTPS 后改成真实地址。
FRONTEND_BASE_URL=http://localhost:3000

# LiteLLM 外部 PostgreSQL 连接串。
# 建议与 New API 使用不同数据库或不同 schema，避免表结构互相污染。
# 本地 Docker Desktop 连接宿主机 PostgreSQL 示例：
# DATABASE_URL=postgresql://litellm:password@host.docker.internal:5432/litellm
DATABASE_URL=postgresql://litellm:CHANGE_ME@postgres.example.internal:5432/litellm

# New API 外部 PostgreSQL 连接串。
# 本地 Docker Desktop 连接宿主机 PostgreSQL 示例：
# SQL_DSN=postgresql://newapi:password@host.docker.internal:5432/newapi
SQL_DSN=postgresql://newapi:CHANGE_ME@postgres.example.internal:5432/newapi

# New API 外部 Redis 连接串。
# 本地 Docker Desktop 连接宿主机 Redis 示例：
# REDIS_CONN_STRING=redis://host.docker.internal:6379/0
REDIS_CONN_STRING=redis://redis.example.internal:6379/0

# LiteLLM 管理 API 和 UI 登录的主密钥。按 root 密码级别保管，不发给员工。
LITELLM_MASTER_KEY=sk-CHANGE_ME_GENERATE_RANDOM_VALUE

# LiteLLM 用于加密/解密已保存凭据的盐值。首次部署后必须保持稳定。
LITELLM_SALT_KEY=sk-CHANGE_ME_GENERATE_RANDOM_VALUE

# New API 会话签名密钥。修改后会使已有登录会话失效。
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE

# New API 数据加密密钥。修改后可能导致已加密数据无法读取。
CRYPTO_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE

# New API 服务 token。
# 这是 LiteLLM 调用 New API 的“服务账号 token”，不是员工 token。
# 员工只拿 LiteLLM 发放的 virtual key，不直接拿这个 token。
NEW_API_SERVICE_TOKEN=sk-CHANGE_ME_CREATE_IN_NEW_API

# LiteLLM 调 New API 的 OpenAI-compatible 地址。
# 在同一个 docker-compose 网络里使用服务名 new-api，不要写 localhost。
NEW_API_OPENAI_BASE_URL=http://new-api:3000/v1

# New API 团队默认策略。
# false 表示 New API 不自动创建默认 token，由管理员显式发放服务 token。
GENERATE_DEFAULT_TOKEN=false

# 开启服务端错误日志，便于排查渠道池问题。
ERROR_LOG_ENABLED=true

# 开启批量用量更新，适合团队用量统计。
BATCH_UPDATE_ENABLED=true

# 开启内存缓存，提高请求性能。
MEMORY_CACHE_ENABLED=true

# 流式响应超时时间，单位秒。Claude Code / 编码 agent 可能需要较长流式输出。
STREAMING_TIMEOUT=300

# 公共 API 按来源 IP 的粗粒度限流。真正员工配额建议放在 LiteLLM virtual key 上。
GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=300
GLOBAL_API_RATE_LIMIT_DURATION=180

# New API 定期从渠道同步上游模型列表。
CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true

# 可选：如果服务器访问上游模型供应商需要代理，在这里配置。
# Docker 容器访问宿主机代理常用 host.docker.internal。
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
# http_proxy=http://host.docker.internal:7897
# https_proxy=http://host.docker.internal:7897
# NO_PROXY=localhost,127.0.0.1,new-api,litellm,host.docker.internal,.internal
# no_proxy=localhost,127.0.0.1,new-api,litellm,host.docker.internal,.internal
